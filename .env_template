# Python base image used to build the WebUI container
PYTHON_IMAGE=python:3.14-slim
# Nginx image used by the reverse proxy container
NGINX_IMAGE=nginx:1.30-alpine

# Bitcoin Core Docker image repository (used by bitcoind and also as a build stage for bitcoin-cli)
BITCOIN_REPO=bitcoin/bitcoin
# Bitcoin Core Docker image tag/version
BITCOIN_VERSION=30.0

# Hostname of the bitcoind container on the Docker Compose network
BITCOIND_HOST=bitcoind
# JSON-RPC port exposed by bitcoind inside the Docker network
BITCOIND_PORT=18443
# JSON-RPC username used by the WebUI to authenticate to bitcoind
BITCOIND_USER=bitcoin
# JSON-RPC password used by the WebUI to authenticate to bitcoind
BITCOIND_PASS=bitcoin

# Host port to publish the WebUI (nginx proxy) on localhost
HOST_PORT=8181
