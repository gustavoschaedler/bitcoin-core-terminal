  "help": {
    "title": "Dicas",
    "cards": [
      {
        "title": "Como usar",
        "lines": [
          "Digite um comando RPC (ex.: <code>getblockchaininfo</code>) e aperte <kbd>Enter</kbd>",
          "Use <code>-rpcwallet=NOME</code> para escolher a wallet",
          "Use <code>-generate</code> para minerar em regtest (precisa de wallet)"
        ]
      },
      {
        "title": "Terminal",
        "lines": [
          "Comece com <code>!</code> para executar comandos de shell dentro do container",
          "<kbd>↑</kbd>/<kbd>↓</kbd> histórico, <kbd>Tab</kbd> autocomplete, <kbd>Ctrl</kbd>+<kbd>L</kbd> limpa"
        ]
      },
      {
        "title": "RPC",
        "lines": [
          "Parâmetros: <code>getblock \"HASH\" 2</code> ou <code>sendtoaddress \"addr\" 1.0</code>",
          "Wallet: <code>-rpcwallet=NOME</code> (ex.: <code>getbalance -rpcwallet=minha_wallet</code>)",
          "Regtest: <code>-generate</code> minera blocos (usa <code>generatetoaddress</code>)"
        ]
      },
      {
        "title": "Teclas",
        "lines": [
          "<kbd>Enter</kbd> executa, <kbd>Shift</kbd>+<kbd>Enter</kbd> quebra linha",
          "<kbd>Ctrl</kbd>+<kbd>L</kbd> limpa o terminal",
          "<kbd>Tab</kbd> completa comandos (baseado nos snippets)"
        ]
      },
      {
        "title": "Wallets",
        "lines": [
          "<code>createwallet \"minha_wallet\"</code> cria",
          "<code>loadwallet \"minha_wallet\"</code> carrega",
          "<code>listwallets</code> lista"
        ]
      },
      {
        "title": "Snippets",
        "lines": [
          "Clique em um snippet para inserir no terminal ativo",
          "Use a busca para filtrar; o texto do comando é destacado",
          "Os grupos podem ser recolhidos/expandidos"
        ]
      }
    ]
  },
