  "help": {
    "title": "Tips",
    "cards": [
      {
        "title": "How to use",
        "lines": [
          "Type an RPC command (e.g. <code>getblockchaininfo</code>) and press <kbd>Enter</kbd>",
          "Use <code>-rpcwallet=NAME</code> to target a wallet",
          "Use <code>-generate</code> to mine on regtest (requires a wallet)"
        ]
      },
      {
        "title": "Terminal",
        "lines": [
          "Start with <code>!</code> to run shell commands inside the container",
          "<kbd>↑</kbd>/<kbd>↓</kbd> history, <kbd>Tab</kbd> autocomplete, <kbd>Ctrl</kbd>+<kbd>L</kbd> clears"
        ]
      },
      {
        "title": "RPC",
        "lines": [
          "Parameters: <code>getblock \"HASH\" 2</code> or <code>sendtoaddress \"addr\" 1.0</code>",
          "Wallet: <code>-rpcwallet=NAME</code> (e.g. <code>getbalance -rpcwallet=my_wallet</code>)",
          "Regtest: <code>-generate</code> mines blocks (uses <code>generatetoaddress</code>)"
        ]
      },
      {
        "title": "Keys",
        "lines": [
          "<kbd>Enter</kbd> runs, <kbd>Shift</kbd>+<kbd>Enter</kbd> inserts a newline",
          "<kbd>Ctrl</kbd>+<kbd>L</kbd> clears the terminal",
          "<kbd>Tab</kbd> completes commands (based on snippets)"
        ]
      },
      {
        "title": "Wallets",
        "lines": [
          "<code>createwallet \"my_wallet\"</code> creates",
          "<code>loadwallet \"my_wallet\"</code> loads",
          "<code>listwallets</code> lists"
        ]
      },
      {
        "title": "Snippets",
        "lines": [
          "Click a snippet to insert it into the active terminal",
          "Use search to filter; matches are highlighted",
          "Groups can be collapsed/expanded"
        ]
      }
    ]
  },
